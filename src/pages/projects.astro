    description="Nathan Addison's web development portfolio showcasing websites, web applications, and creative projects. View some of my work in web development and design."
    ogDescription="Explore Nathan Addison's web development portfolio featuring custom websites, web applications, and creative digital projects."
    imageAlt="Nathan Addison Portfolio"
    path="/projects.html"
    structuredData={structuredData}
    current="projects"
>
    <div class="page-header" data-elevate>
        <h1 class="intro-header">Portfolio & Projects</h1>
        <p class="page-subtitle">A collection of client work and personal projects — each one a different challenge.</p>
    </div>

    <section class="portfolio-section glass-card">
        <h2 class="section-title">Personal Projects</h2>
        <ul class="project-list" data-elevate>
            {personalProjects.map((project) => <ProjectCard {...project} />)}
        </ul>
    </section>

    <section class="portfolio-section glass-card">

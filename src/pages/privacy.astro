---
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Privacy Policy",
    description: "Privacy policy for Logie Web Services NZ outlining data collection, usage, and security practices in accordance with Privacy Act 2020.",
    url: "https://www.logie.nz/privacy.html",
    inLanguage: "en-NZ",
    isPartOf: {
        "@type": "WebSite",
        name: "Logie Web Services NZ",
        url: "https://www.logie.nz",
    },
    datePublished: "2025-04-06",
    dateModified: "2025-04-06",
};
---

<BaseLayout
    title="Privacy Policy - Logie Web Services"
    description="Privacy policy for Logie Web Services NZ. Learn how we collect, use, and protect your personal information in accordance with New Zealand Privacy Act 2020 and GDPR."
    ogDescription="Privacy policy for Logie Web Services NZ outlining data collection, usage, and security practices."
    path="/privacy.html"
    twitterCard="summary"
    structuredData={structuredData}
>
    <h1 class="privacy-title">Privacy Notice</h1>
    <div class="privacy-content" data-elevate>
        <div class="privacy-section">
            <h2>Information Collection</h2>
            <p class="privacy-text">
                I may collect personal information from you, including:
            </p>
            <p class="privacy-text">
                • Full name<br />
                • Contact information (such as: phone number, e-mail address)<br />
                • Project requirements and communications<br />
                • Payment information (when applicable)<br />
                • Website usage data (if analytics are implemented on your completed website)
            </p>
        </div>

        <div class="privacy-section">
            <h2>Purpose of Collection</h2>
            <p class="privacy-text">
                I collect your personal information in order to:
            </p>
            <p class="privacy-text">
                • Provide web development services and discuss project needs<br />
                • Communicate about project requirements and progress<br />
                • Process payments and send invoices<br />
                • Meet legal and regulatory requirements<br />
                • Maintain necessary business records<br />
                • Improve my services and user experience
            </p>
        </div>

        <div class="privacy-section">
            <h2>Optional Information</h2>
            <p class="privacy-text">
                Providing some information is optional. If you choose not to enter certain details, I may be unable
                to provide adequate service. I will clearly indicate which information is mandatory for service
                provision.
            </p>
        </div>

        <div class="privacy-section">
            <h2>Data Storage and Security</h2>
            <p class="privacy-text">
                I keep your information safe by storing it in a secure, encrypted environment with access limited to
                myself (the developer). I maintain regular security updates and monitoring, along with secure backup
                procedures. Client data is retained for as long as needed for business purposes or as required by
                law, typically for 7 years for financial records.
            </p>
        </div>

        <div class="privacy-section">
            <h2>Information Sharing</h2>
            <p class="privacy-text">
                I do not sell your personal information to third parties. I may only share your information with:
            </p>
            <p class="privacy-text">
                • Service providers necessary for website functionality (e.g., hosting services, payment
                processors)<br />
                • Legal authorities when required by law<br />
                • Professional advisors (e.g., accountants, lawyers) when necessary
            </p>
            <p class="privacy-text">
                Any third parties who receive your data are required to maintain the confidentiality and security of
                your information.
            </p>
        </div>

        <div class="privacy-section">
            <h2>Cookies and Tracking</h2>
            <p class="privacy-text">
                I may use cookies, analytics, or similar technologies on websites I develop to enhance the user
                experience and collect anonymous usage data. You can adjust your browser settings to refuse cookies,
                but this may limit certain website functionalities.
            </p>
        </div>

        <div class="privacy-section">
            <h2>Your Rights</h2>
            <p class="privacy-text">
                Under the Privacy Act 2020, you have the right to:
            </p>
            <p class="privacy-text">
                • Access your personal information<br />
                • Request corrections if you believe information is incorrect<br />
                • Request deletion of your data (where applicable)<br />
                • Make a complaint to the Privacy Commissioner
            </p>
            <p class="privacy-text">
                If you are an EU resident, additional GDPR rights may apply to your data processing, including the
                right to data portability and the right to restrict processing.
            </p>
        </div>

        <div class="privacy-section">
            <h2>Policy Updates</h2>
            <p class="privacy-text">
                I may update this privacy policy periodically to reflect changes in services or legal requirements.
                Significant changes will be communicated to active clients via email.
            </p>
        </div>

        <div class="contact-info">
            <p class="privacy-text">
                If you'd like to request a copy of your information, have it corrected, or have any privacy-related
                questions, please contact me at kiaora@logie.nz.
            </p>
            <p class="privacy-text">
                Last Updated: April 6, 2025
            </p>
        </div>
    </div>
</BaseLayout>

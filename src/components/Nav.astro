---
import ThemeSwitch from "./ThemeSwitch.astro";

export interface Props {
    current?: "projects" | "faq" | "blog";
}

const { current } = Astro.props;
---

<nav class="nav">
    <div class="logo-container">
        <a class="logo" href="/">
            <span class="logo-text">Logie</span>
            <span class="logo-accent">Web Services</span>
            <span class="logo-semicolon">|</span>
        </a>
    </div>

    <div class="nav-links">
        <a href="https://form.jotform.com/243067662032856" class="nav-link">
            <span class="nav-link-icon-wrapper">
                <svg class="nav-link-icon" viewBox="0 0 24 24">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
            </span>
            <span class="nav-link-text">Free Quote</span>
        </a>
        <a class={`nav-link${current === "projects" ? " active" : ""}`} href="/projects.html">
            <span class="nav-link-icon-wrapper">
                <svg class="nav-link-icon" viewBox="0 0 24 24">
                    <path d="M3 7h18v13H3V7z"/>
                    <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
            </span>
            <span class="nav-link-text">Portfolio</span>
        </a>
        <a class={`nav-link${current === "blog" ? " active" : ""}`} href="/blog.html">
            <span class="nav-link-icon-wrapper">
                <svg class="nav-link-icon" viewBox="0 0 24 24">
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
            </span>
            <span class="nav-link-text">Blog</span>
        </a>
        <a class={`nav-link${current === "faq" ? " active" : ""}`} href="/faq.html">
            <span class="nav-link-icon-wrapper">
                <svg class="nav-link-icon" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 2-3 4"/>
                    <path d="M12 17h.01"/>
                </svg>
            </span>
            <span class="nav-link-text">FAQ</span>
        </a>
    </div>

    <ThemeSwitch />
</nav>

<script>
    import { gsap } from "gsap";

    const nav = document.querySelector(".nav-links");
    if (nav) {
        if (window.innerWidth < 1024) {
            gsap.set(nav, { autoAlpha: 0, yPercent: 100 });
            gsap.to(nav, { autoAlpha: 1, yPercent: 0, ease: "power2.out", duration: 0.5, delay: 0.4 });
        } else {
            gsap.set(nav, { autoAlpha: 0 });
            gsap.to(nav, { autoAlpha: 1, duration: 0.4 });
        }
    }
</script>

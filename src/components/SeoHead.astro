---
export interface Props {
    title: string;
    description: string;
    ogDescription?: string;
    twitterDescription?: string;
    path: string;
    ogType?: string;
    twitterCard?: "summary" | "summary_large_image";
    imageAlt?: string;
    structuredData: Record<string, unknown>;
}

const {
    title,
    description,
    ogDescription,
    twitterDescription,
    path,
    ogType = "website",
    twitterCard = "summary_large_image",
    imageAlt = "Logie Web Services Logo",
    structuredData,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://www.logie.nz";
const url = new URL(path, siteOrigin).toString();
const image = new URL("/assets/images/logienz.webp", siteOrigin).toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />

<!-- Open Graph Meta Tags -->
<meta property="og:title" content={title} />
<meta property="og:site_name" content="Logie Web Services" />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:image" content={image} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={url} />
<meta property="og:locale" content="en_NZ" />

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={twitterDescription ?? ogDescription ?? description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={imageAlt} />

<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="/assets/images/favicon.ico" />
<link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
<link rel="manifest" href="/assets/site.webmanifest" />

<link rel="canonical" href={url} />

<title>{title}</title>

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData, null, 2)} />

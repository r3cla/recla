<button
    id="theme-switch"
    class="theme-switch"
    type="button"
    role="switch"
    aria-checked="true"
    aria-label="Toggle light/dark theme"
>
    <svg class="theme-switch-icon theme-switch-icon--sun" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
    </svg>
    <svg class="theme-switch-icon theme-switch-icon--moon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
    </svg>
</button>

<script>
    const button = document.getElementById("theme-switch");
    const html = document.documentElement;

    function applyScheme(isDark: boolean): void {
        html.classList.toggle("dark-scheme", isDark);
        html.classList.toggle("light-scheme", !isDark);
        button?.setAttribute("aria-checked", String(isDark));
        localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    if (button) {
        button.setAttribute("aria-checked", String(html.classList.contains("dark-scheme")));
        button.addEventListener("click", () => {
            applyScheme(!html.classList.contains("dark-scheme"));
        });
    }
</script>
